{"version": 2, "width": 90, "height": 24, "timestamp": 1742659200, "env": {"SHELL": "/bin/zsh", "TERM": "xterm-256color"}, "title": "ruth-cli — Agent-friendly TOTP authenticator"}
[0.5, "o", "\u001b[1;32m❯\u001b[0m "]
[1.2, "o", "# ruth-cli: Agent-friendly TOTP authenticator"]
[1.8, "o", "\r\n"]
[2.3, "o", "\u001b[1;32m❯\u001b[0m "]
[2.8, "o", "# Step 1: Add a TOTP entry from a QR code image"]
[3.4, "o", "\r\n"]
[3.9, "o", "\u001b[1;32m❯\u001b[0m "]
[4.3, "o", "r"]
[4.35, "o", "u"]
[4.4, "o", "t"]
[4.45, "o", "h"]
[4.5, "o", "-"]
[4.55, "o", "c"]
[4.6, "o", "l"]
[4.65, "o", "i"]
[4.75, "o", " "]
[4.85, "o", "a"]
[4.9, "o", "d"]
[4.95, "o", "d"]
[5.05, "o", " "]
[5.15, "o", "-"]
[5.2, "o", "q"]
[5.3, "o", " "]
[5.4, "o", "~/Downloads/aws-qr.png"]
[6.0, "o", "\r\n"]
[6.5, "o", "Added entry '\u001b[1maws-prod\u001b[0m'. Use `ruth-cli get aws-prod` to get the code.\r\n"]
[7.5, "o", "\u001b[1;32m❯\u001b[0m "]
[8.0, "o", "# Step 2: Add another entry manually"]
[8.6, "o", "\r\n"]
[9.1, "o", "\u001b[1;32m❯\u001b[0m "]
[9.5, "o", "ruth-cli add -l github -d github.com -a dev@company.com -s JBSWY3DPEHPK3PXP"]
[10.3, "o", "\r\n"]
[10.8, "o", "Added entry '\u001b[1mgithub\u001b[0m'. Use `ruth-cli get github` to get the code.\r\n"]
[11.8, "o", "\u001b[1;32m❯\u001b[0m "]
[12.3, "o", "# Step 3: List all entries"]
[12.9, "o", "\r\n"]
[13.4, "o", "\u001b[1;32m❯\u001b[0m "]
[13.8, "o", "ruth-cli list"]
[14.3, "o", "\r\n"]
[14.8, "o", "\u001b[1;36maws-prod\u001b[0m     aws.amazon.com     admin@company.com\r\n"]
[14.9, "o", "\u001b[1;36mgithub\u001b[0m       github.com         dev@company.com\r\n"]
[16.0, "o", "\u001b[1;32m❯\u001b[0m "]
[16.5, "o", "# Step 4: Get a TOTP code — outputs ONLY the code to stdout"]
[17.1, "o", "\r\n"]
[17.6, "o", "\u001b[1;32m❯\u001b[0m "]
[18.0, "o", "ruth-cli get github"]
[18.5, "o", "\r\n"]
[19.0, "o", "\u001b[1;33m482937\u001b[0m\r\n"]
[20.0, "o", "\u001b[1;32m❯\u001b[0m "]
[20.5, "o", "# Step 5: Use in scripts — perfect for AI agents and automation"]
[21.1, "o", "\r\n"]
[21.6, "o", "\u001b[1;32m❯\u001b[0m "]
[22.0, "o", "TOKEN=$(ruth-cli get aws-prod) && echo \"Got MFA token: $TOKEN\""]
[22.8, "o", "\r\n"]
[23.3, "o", "Got MFA token: \u001b[1;33m759214\u001b[0m\r\n"]
[24.3, "o", "\u001b[1;32m❯\u001b[0m "]
[24.8, "o", "# Step 6: Agent workflow — Claude Code using ruth-cli"]
[25.4, "o", "\r\n"]
[25.9, "o", "\u001b[1;32m❯\u001b[0m "]
[26.3, "o", "# claude> \"Log in to AWS console with MFA\""]
[26.9, "o", "\r\n"]
[27.4, "o", "\u001b[1;32m❯\u001b[0m "]
[27.8, "o", "MFA_TOKEN=$(ruth-cli get aws-prod)"]
[28.4, "o", "\r\n"]
[28.9, "o", "\u001b[1;32m❯\u001b[0m "]
[29.3, "o", "aws sts get-session-token --serial-number arn:aws:iam::mfa/admin --token-code $MFA_TOKEN"]
[30.1, "o", "\r\n"]
[30.6, "o", "{\r\n"]
[30.7, "o", "    \"Credentials\": {\r\n"]
[30.8, "o", "        \"AccessKeyId\": \"ASIA...\",\r\n"]
[30.9, "o", "        \"SecretAccessKey\": \"***\",\r\n"]
[31.0, "o", "        \"SessionToken\": \"FwoGZX...\",\r\n"]
[31.1, "o", "        \"Expiration\": \"2026-03-22T22:00:00Z\"\r\n"]
[31.2, "o", "    }\r\n"]
[31.3, "o", "}\r\n"]
[32.3, "o", "\u001b[1;32m❯\u001b[0m "]
[32.8, "o", "# Secrets are GPG-encrypted at rest. Decrypted content never touches disk."]
[33.4, "o", "\r\n"]
[33.9, "o", "\u001b[1;32m❯\u001b[0m "]
[34.4, "o", "# Install: brew install zhongdai/tap/ruth-cli"]
[35.0, "o", "\r\n"]
[35.5, "o", "\u001b[1;32m❯\u001b[0m "]
[36.5, "o", "\r\n"]
